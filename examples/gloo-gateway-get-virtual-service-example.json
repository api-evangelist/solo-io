{
  "metadata": {
    "name": "petstore",
    "namespace": "gloo-system",
    "cluster": "production",
    "labels": {
      "app": "petstore"
    },
    "annotations": {
      "kubectl.kubernetes.io/last-applied-configuration": ""
    },
    "resourceVersion": "99871"
  },
  "status": {
    "state": "Accepted",
    "reason": "",
    "reportedBy": "gloo"
  },
  "displayName": "Petstore API Virtual Service",
  "domains": ["petstore.example.com", "api.example.com"],
  "routes": [
    {
      "name": "petstore-api-route",
      "matchers": [
        {
          "prefix": "/api/v1",
          "methods": ["GET", "POST", "PUT", "DELETE"]
        }
      ],
      "routeAction": {
        "single": {
          "upstream": {
            "name": "default-petstore-8080",
            "namespace": "gloo-system"
          }
        }
      },
      "options": {
        "timeout": "30s",
        "retries": {
          "retryOn": "connect-failure,retriable-4xx",
          "numRetries": 3
        }
      }
    }
  ],
  "sslConfig": {
    "secretRef": {
      "name": "petstore-tls",
      "namespace": "gloo-system"
    }
  }
}
